# TMDB server-side credentials. Set either a read access token or legacy API key.
TMDB_API_TOKEN=
TMDB_API_KEY=

# Supabase public client configuration for the production data layer.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Required server-only key for authoritative movie-cache writes and maintenance jobs.
# Prefer the current sb_secret_ key. Legacy projects may use service_role instead.
# Never expose either value with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Canonical production origin, for example https://postcredits.example.com.
SITE_URL=
